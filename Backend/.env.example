# Copy this to .env and fill in real values — never commit .env to git

# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your-jwt-secret-here

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/finance_db?retryWrites=true&w=majority

# Google Gemini API key — get from https://aistudio.google.com/app/apikeys
AI_API_KEY=your-gemini-api-key-here
